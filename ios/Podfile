# Use CDN for specs (faster than full repo clone). Only run 'pod install' when Podfile or native deps change.
source 'https://cdn.cocoapods.org/'

require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Default off to match android/gradle.properties newArchEnabled=false. RN iOS treats unset
# RCT_NEW_ARCH_ENABLED as enabled (NewArchitectureHelper), which pulls Fabric codegen paths
# that can break (e.g. ReactCodegen missing RNDateTimePickerCGen/States.h). Set RCT_NEW_ARCH_ENABLED=1 before pod install to opt in.
ENV['RCT_NEW_ARCH_ENABLED'] = ENV.fetch('RCT_NEW_ARCH_ENABLED', '0')

# Ensure generated dir exists so CpHeader for ReactAppDependencyProvider etc. can write into it
FileUtils.mkdir_p(File.join(__dir__, 'build', 'generated', 'ios'))

$RNFirebaseAsStaticFramework = true

target 'SugarCare' do
  config = use_native_modules!

  use_frameworks! :linkage => :static

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :hermes_enabled => false
  )

  # Firebase (Messaging is included in Firebase umbrella; use_native_modules adds RNFBMessaging)
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseAuth', :modular_headers => true
  pod 'FirebaseFirestore', :modular_headers => true
  pod 'FirebaseStorage', :modular_headers => true
  pod 'Firebase', :modular_headers => true

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = min_ios_version_supported
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'
        # Required for React-Core and other framework pods with Xcode 16+ (avoids "non-modular include in framework module" errors)
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        # Avoid "Explicit modules is enabled but the compiler was not recognized" (Xcode 16+ / ccache)
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'

        # Build speed: Debug-only optimizations
        if config.name == 'Debug'
          config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
          config.build_settings['GCC_OPTIMIZATION_LEVEL'] = '0'
          config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
        end

        # FIX: Ensure Firebase headers are visible to all pods
        config.build_settings['HEADER_SEARCH_PATHS'] ||= '$(inherited) '
        config.build_settings['HEADER_SEARCH_PATHS'] << '"$(PODS_ROOT)/Headers/Public/Firebase" '
      end
    end
  end
end